generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rezervasyon {
  id         Int       @id @default(autoincrement())
  name       String
  email      String
  phone      String
  date       String
  time       String
  guests     Int
  notes      String?
  status     String    @default("bekliyor")
  createdAt  DateTime  @default(now())
  musteriId  Int?
  musteri    Musteri?  @relation(fields: [musteriId], references: [id])
  masaId     Int?
  masa       Masa?     @relation(fields: [masaId], references: [id], onDelete: SetNull)
}

model Musteri {
  id           Int            @id @default(autoincrement())
  name         String
  email        String         @unique
  phone        String?
  dogumGunu    String?        // YYYY-MM-DD
  vip          Boolean        @default(false)
  notlar       String?
  createdAt    DateTime       @default(now())
  rezervasyonlar Rezervasyon[]
  ziyaretler   MusteriZiyaret[]
}

model StokItem {
  id         Int            @id @default(autoincrement())
  name       String
  birim      String         @default("adet") // adet | kg | litre | gr | ml
  miktar     Float          @default(0)
  minMiktar  Float          @default(5)
  kategori   String         @default("Malzeme") // Malzeme | İçecek | Ambalaj | Temizlik
  createdAt  DateTime       @default(now())
  hareketler StokHareket[]
  menuItems  MenuItemStok[]
}

model StokHareket {
  id          Int       @id @default(autoincrement())
  stokItemId  Int
  stokItem    StokItem  @relation(fields: [stokItemId], references: [id], onDelete: Cascade)
  tip         String    // giris | cikis
  miktar      Float
  aciklama    String?
  createdAt   DateTime  @default(now())
}

model MusteriZiyaret {
  id         Int      @id @default(autoincrement())
  musteriId  Int
  musteri    Musteri  @relation(fields: [musteriId], references: [id])
  tarih      String
  kisiSayisi Int
  not        String?
  createdAt  DateTime @default(now())
}

model MenuItem {
  id        Int              @id @default(autoincrement())
  name      String
  desc      String
  price     String
  category  String
  image          String?
  happyHourPrice String?
  active         Boolean          @default(true)
  order     Int              @default(0)
  createdAt DateTime         @default(now())
  stoklar   MenuItemStok[]
}

model MenuItemStok {
  id          Int      @id @default(autoincrement())
  menuItemId  Int
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  stokItemId  Int
  stokItem    StokItem @relation(fields: [stokItemId], references: [id], onDelete: Cascade)
  miktar      Float    @default(1) // bu menü ürününde kullanılan stok miktarı
}

model GaleriItem {
  id        Int      @id @default(autoincrement())
  url       String
  alt       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Ayar {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Masa {
  id           Int            @id @default(autoincrement())
  no           Int            @unique
  kapasite     Int            @default(4)
  alan         String         @default("Salon")
  durum        String         @default("bos") // bos | dolu | rezerveli
  posX         Float          @default(50)
  posY         Float          @default(50)
  aktif        Boolean        @default(true)
  talepler     MasaTalebi[]
  siparisler   Siparis[]
  rezervasyonlar Rezervasyon[]
}

model Siparis {
  id        Int           @id @default(autoincrement())
  masaId    Int?
  masa      Masa?         @relation(fields: [masaId], references: [id])
  durum     String        @default("bekliyor") // bekliyor | hazirlaniyor | hazir | teslim
  notlar    String?
  items     SiparisItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model SiparisItem {
  id         Int     @id @default(autoincrement())
  siparisId  Int
  siparis    Siparis @relation(fields: [siparisId], references: [id], onDelete: Cascade)
  menuItemId Int
  name       String
  price      String
  adet       Int     @default(1)
  not        String?
}

model Odeme {
  id        Int      @id @default(autoincrement())
  masaId    Int?
  tutar     Float
  yontem    String   @default("nakit") // nakit | kart | havale
  notlar    String?
  createdAt DateTime @default(now())
}

model MasaTalebi {
  id        Int      @id @default(autoincrement())
  masaId    Int
  masa      Masa     @relation(fields: [masaId], references: [id])
  tip       String   // garson | hesap
  durum     String   @default("bekliyor") // bekliyor | tamam
  createdAt DateTime @default(now())
}
