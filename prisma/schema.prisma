generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Rezervasyon {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  date      String
  time      String
  guests    Int
  notes     String?
  status    String   @default("bekliyor")
  createdAt DateTime @default(now())
}

model MenuItem {
  id       Int     @id @default(autoincrement())
  name     String
  desc     String
  price    String
  category String
  active   Boolean @default(true)
  order    Int     @default(0)
  createdAt DateTime @default(now())
}

model GaleriItem {
  id        Int      @id @default(autoincrement())
  url       String
  alt       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Ayar {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
